{
  "name": "llm-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Persistent LLM-maintained wiki scaffold for Obsidian-style knowledge bases.",
  "scripts": {
    "init": "node scripts/llm-wiki.mjs init",
    "auth": "node scripts/llm-wiki.mjs auth",
    "ingest": "node scripts/llm-wiki.mjs ingest",
    "query": "node scripts/llm-wiki.mjs query",
    "search": "node scripts/llm-wiki.mjs search",
    "graph": "node scripts/llm-wiki.mjs graph",
    "lint": "node scripts/llm-wiki.mjs lint",
    "repair": "node scripts/llm-wiki.mjs repair",
    "test": "node --test tests/*.test.mjs",
    "build": "node scripts/llm-wiki.mjs build-site",
    "build:site": "node scripts/llm-wiki.mjs build-site",
    "vercel-build": "node scripts/llm-wiki.mjs build-site",
    "serve": "node scripts/llm-wiki.mjs serve",
    "deploy": "node scripts/llm-wiki.mjs deploy --prod --yes",
    "status": "node scripts/llm-wiki.mjs status"
  },
  "dependencies": {
    "firebase": "^12.11.0"
  }
}
